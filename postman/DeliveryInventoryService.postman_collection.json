          "name": "List Rider Parcels",
          "request": {
            "method": "GET",
            "header": [],
            "description": "Lists parcels assigned to a rider. Role can be `pickup` or `delivery`.\n\n```bash\ncurl '{{baseUrl}}/api/v1/admin/warehouse/riders/{{riderId}}/parcels?role=pickup'\n```",
            "url": "{{baseUrl}}/api/v1/admin/warehouse/riders/{{riderId}}/parcels?role=pickup"
          }
        },
