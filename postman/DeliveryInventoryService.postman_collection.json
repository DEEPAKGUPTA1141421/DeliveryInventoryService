          "name": "List Warehouse Parcels",
          "request": {
            "method": "GET",
            "header": [],
            "description": "Lists parcels for a warehouse. Optional status values include `CREATED`, `AWAITING_PICKUP`, `AT_WAREHOUSE`, `IN_SHIPMENT`, `OUT_FOR_DELIVERY`, `DELIVERED`.\n\n```bash\ncurl '{{baseUrl}}/api/v1/admin/warehouse/{{warehouseId}}/parcels?status=CREATED'\n```",
            "url": "{{baseUrl}}/api/v1/admin/warehouse/{{warehouseId}}/parcels?status=CREATED"
          }
        },
