              "raw": "{\n  \"customerId\": \"0f858d4a-4b48-4e0d-9d9e-2df8cf66af7c\",\n  \"bookingId\": \"19f63a8a-1a93-49d8-b32c-f5f87d0784f1\",\n  \"riderId\": null,\n  \"distance\": 12.5,\n  \"wareHouseId\": \"{{warehouseId}}\",\n  \"originAddress\": \"Connaught Place, Delhi\",\n  \"originLat\": 28.6315,\n  \"originLng\": 77.2167,\n  \"originCity\": \"Delhi\",\n  \"destAddress\": \"Sector 18, Noida\",\n  \"destLat\": 28.5708,\n  \"destLng\": 77.3261,\n  \"destCity\": \"Noida\",\n  \"weightKg\": 5.0,\n  \"serviceType\": \"STANDARD\",\n  \"status\": \"CREATED\",\n  \"expectedDeliveryDate\": \"2026-05-10T18:00:00+05:30\"\n}"
