            "body": {
              "mode": "raw",
              "raw": "{\n  \"shipmentType\": \"LONG_HAUL\",\n  \"originWarehouseId\": \"{{warehouseId}}\",\n  \"destinationWarehouseId\": \"{{destinationWarehouseId}}\",\n  \"parcelIds\": [\n    \"{{parcelId}}\"\n  ],\n  \"vehicleId\": \"{{vehicleId}}\",\n  \"departureTimeEst\": \"2026-05-10T10:00:00+05:30\",\n  \"arrivalTimeEst\": \"2026-05-10T14:00:00+05:30\"\n}"
