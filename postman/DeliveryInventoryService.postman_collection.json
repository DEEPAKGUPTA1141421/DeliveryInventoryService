              "raw": "{\n  \"orderId\": \"{{orderId}}\",\n  \"weightKg\": 5.0,\n  \"dimensions\": \"30x20x15 cm\",\n  \"description\": \"Electronics package\",\n  \"originWarehouseId\": \"{{warehouseId}}\",\n  \"destinationWarehouseId\": \"{{destinationWarehouseId}}\"\n}"
            },
            "description": "Creates a parcel from an order.\n\n```bash\ncurl -X POST '{{baseUrl}}/api/v1/admin/warehouse/parcels' -H 'Content-Type: application/json' -d '{\"orderId\":\"{{orderId}}\",\"weightKg\":5.0,\"dimensions\":\"30x20x15 cm\",\"description\":\"Electronics package\",\"originWarehouseId\":\"{{warehouseId}}\",\"destinationWarehouseId\":\"{{destinationWarehouseId}}\"}'\n```",
            "url": "{{baseUrl}}/api/v1/admin/warehouse/parcels"
          }
        },
        {
          "name": "Get Parcel By Id",
          "request": {
            "method": "GET",
            "header": [],
            "description": "Fetches parcel details.\n\n```bash\ncurl '{{baseUrl}}/api/v1/admin/warehouse/parcels/{{parcelId}}'\n```",
            "url": "{{baseUrl}}/api/v1/admin/warehouse/parcels/{{parcelId}}"
          }
        },
